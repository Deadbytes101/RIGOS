#!/usr/bin/python3
from __future__ import annotations

import argparse
import json
import os
import re
import stat
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Iterator

ATTESTATION = Path(os.environ.get("RIGOS_IDENTITY_ATTESTATION", "/run/rigos/boot-device.json"))
STATE_STATUS = Path(os.environ.get("RIGOS_IDENTITY_STATE_STATUS", "/run/rigos/state-status.json"))
BOOT_ID = Path(os.environ.get("RIGOS_IDENTITY_BOOT_ID", "/proc/sys/kernel/random/boot_id"))
STATE_INIT = os.environ.get("RIGOS_IDENTITY_STATE_INIT", "/usr/lib/rigos/rigos-state-init")
MOUNT = os.environ.get("RIGOS_IDENTITY_MOUNT", "/usr/bin/mount")
UMOUNT = os.environ.get("RIGOS_IDENTITY_UMOUNT", "/usr/bin/umount")
FINDMNT = os.environ.get("RIGOS_IDENTITY_FINDMNT", "/usr/bin/findmnt")
RUNTIME = Path(os.environ.get("RIGOS_IDENTITY_RUNTIME", "/run/rigos"))
MAX_SEED_BYTES = 4096
MAX_IDENTITY_BYTES = 512
MAX_SEED_FILES = 128
SLUG_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9-]{0,63}$")
SAFE_JSON_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]{0,122}\.json$")


class SeedError(Exception):
    def __init__(
        self,
        code: str,
        message: str,
        *,
        file: str | None = None,
        key: str | None = None,
    ) -> None:
        super().__init__(message)
        self.code = code
        self.message = message
        self.file = file
        self.key = key

    def diagnostic(self) -> dict:
        return {
            "code": self.code,
            "file": self.file,
            "line": None,
            "key": self.key,
            "message": self.message,
        }


def fail(
    message: str,
    *,
    file: str | None = None,
    key: str | None = None,
    code: str = "RIGOS_IDENTITY_SEED_INVALID",
) -> SeedError:
    return SeedError(code, message, file=file, key=key)


def read_json(path: Path, message: str) -> dict:
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, UnicodeError, json.JSONDecodeError) as error:
        raise fail(message) from error
    if not isinstance(value, dict):
        raise fail(message)
    return value


def folded_hex(value: object) -> str:
    return str(value or "").lower()


def revalidate_attestation() -> dict:
    expected = read_json(ATTESTATION, "boot device attestation is unavailable")
    status = read_json(STATE_STATUS, "persistent state status is unavailable")
    try:
        current_boot_id = BOOT_ID.read_text(encoding="ascii").strip()
    except OSError as error:
        raise fail("current boot identity is unavailable") from error
    if (
        expected.get("schema") != "rigos.boot-device/v1"
        or expected.get("verification_outcome") != "verified"
        or expected.get("boot_id") != current_boot_id
        or status.get("outcome") != "ready"
    ):
        raise fail(
            "verified persistent boot USB is required",
            code="RIGOS_IDENTITY_BOOT_DEVICE_UNPROVEN",
        )

    RUNTIME.mkdir(mode=0o755, parents=True, exist_ok=True)
    with tempfile.TemporaryDirectory(prefix="identity-attestation-", dir=RUNTIME) as temporary:
        root = Path(temporary)
        fresh_path = root / "boot-device.json"
        fresh_status = root / "state-status.json"
        result = subprocess.run(
            [
                STATE_INIT,
                "--dry-run",
                "--attestation-only",
                "--attestation",
                str(fresh_path),
                "--status",
                str(fresh_status),
            ],
            check=False,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        if result.returncode != 0:
            raise fail(
                "boot device revalidation failed",
                code="RIGOS_IDENTITY_BOOT_DEVICE_UNPROVEN",
            )
        fresh = read_json(fresh_path, "fresh boot device attestation is unavailable")

    try:
        matches = (
            fresh.get("schema") == expected.get("schema")
            and fresh.get("verification_outcome") == "verified"
            and fresh.get("boot_id") == expected.get("boot_id")
            and fresh["disk"]["major_minor"] == expected["disk"]["major_minor"]
            and folded_hex(fresh["disk"]["ptuuid"])
            == folded_hex(expected["disk"]["ptuuid"])
            and fresh["partition1"]["major_minor"]
            == expected["partition1"]["major_minor"]
            and folded_hex(fresh["partition1"]["partuuid"])
            == folded_hex(expected["partition1"]["partuuid"])
            and fresh["root"]["major_minor"] == expected["root"]["major_minor"]
        )
    except (KeyError, TypeError):
        matches = False
    if not matches:
        raise fail(
            "boot device identity changed after attestation",
            code="RIGOS_IDENTITY_BOOT_DEVICE_UNPROVEN",
        )
    return fresh


class MountedPartition:
    def __init__(self, attestation: dict) -> None:
        self.attestation = attestation
        self.temporary: tempfile.TemporaryDirectory[str] | None = None
        self.root: Path | None = None
        self.mounted = False

    def __enter__(self) -> Path:
        self.temporary = tempfile.TemporaryDirectory(prefix="identity-seed-", dir=RUNTIME)
        self.root = Path(self.temporary.name)
        try:
            partition = self.attestation["partition1"]
            result = subprocess.run(
                [
                    MOUNT,
                    "-o",
                    "ro,nodev,nosuid,noexec",
                    str(partition["path"]),
                    str(self.root),
                ],
                check=False,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
            if result.returncode != 0:
                raise fail(
                    "verified EFI partition could not be mounted read only",
                    code="RIGOS_IDENTITY_BOOT_DEVICE_UNPROVEN",
                )
            self.mounted = True
            identity = subprocess.run(
                [FINDMNT, "--noheadings", "--output", "MAJ:MIN", "--target", str(self.root)],
                check=False,
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
            )
            if (
                identity.returncode != 0
                or identity.stdout.strip() != str(partition["major_minor"])
            ):
                raise fail(
                    "mounted EFI identity changed after verification",
                    code="RIGOS_IDENTITY_BOOT_DEVICE_UNPROVEN",
                )
            return self.root
        except Exception:
            self.__exit__(*sys.exc_info())
            raise

    def __exit__(self, _type: object, _value: object, _traceback: object) -> None:
        if self.mounted and self.root is not None:
            subprocess.run(
                [UMOUNT, str(self.root)],
                check=False,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
            self.mounted = False
        if self.temporary is not None:
            self.temporary.cleanup()
            self.temporary = None


def unique_object(pairs: list[tuple[str, object]]) -> dict:
    output: dict[str, object] = {}
    for key, value in pairs:
        if key in output:
            raise ValueError(f"duplicate member {key}")
        output[key] = value
    return output


def read_seed_file(path: Path) -> dict:
    name = path.name
    try:
        info = path.lstat()
    except OSError as error:
        raise fail("identity seed metadata is unavailable", file=name) from error
    if not stat.S_ISREG(info.st_mode) or stat.S_ISLNK(info.st_mode):
        raise fail("identity seed must be a regular file", file=name)
    if info.st_size > MAX_SEED_BYTES:
        raise fail("identity seed exceeds 4 KiB", file=name)
    flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
    try:
        descriptor = os.open(path, flags)
    except OSError as error:
        raise fail("identity seed could not be opened safely", file=name) from error
    try:
        opened = os.fstat(descriptor)
        if not stat.S_ISREG(opened.st_mode) or opened.st_size > MAX_SEED_BYTES:
            raise fail("identity seed must be a bounded regular file", file=name)
        raw = os.read(descriptor, MAX_SEED_BYTES + 1)
    finally:
        os.close(descriptor)
    if len(raw) > MAX_SEED_BYTES:
        raise fail("identity seed exceeds 4 KiB", file=name)
    try:
        value = json.loads(raw.decode("utf-8"), object_pairs_hook=unique_object)
    except (UnicodeError, json.JSONDecodeError, ValueError) as error:
        raise fail("identity seed is not strict JSON", file=name) from error
    if not isinstance(value, dict):
        raise fail("identity seed must be a JSON object", file=name)
    expected_keys = {"schema", "alias", "kind", "value"}
    if set(value) != expected_keys:
        raise fail("identity seed fields do not match schema", file=name)
    alias = value.get("alias")
    identity = value.get("value")
    if value.get("schema") != "rigos.identity-seed/v1":
        raise fail("unsupported identity seed schema", file=name, key="schema")
    if value.get("kind") != "mining_identity":
        raise fail("unsupported identity seed kind", file=name, key="kind")
    if not isinstance(alias, str) or SLUG_RE.fullmatch(alias) is None:
        raise fail("identity seed alias is invalid", file=name, key="alias")
    if path.stem != alias:
        raise fail("identity seed alias must match its filename", file=name, key="alias")
    if (
        not isinstance(identity, str)
        or not identity
        or len(identity.encode("utf-8")) > MAX_IDENTITY_BYTES
        or not identity.isascii()
        or any(ord(character) < 33 or ord(character) > 126 for character in identity)
    ):
        raise fail("mining identity value is invalid", file=name, key="value")
    return {
        "schema": "rigos.identity/v1",
        "alias": alias,
        "kind": "mining_identity",
        "value": identity,
        "created_locally": True,
    }


def seed_paths(directory: Path) -> Iterator[Path]:
    try:
        info = directory.lstat()
    except FileNotFoundError:
        return
    except OSError as error:
        raise fail("identity seed directory is unavailable") from error
    if not stat.S_ISDIR(info.st_mode) or stat.S_ISLNK(info.st_mode):
        raise fail("identity seed path must be a directory")
    count = 0
    for path in sorted(directory.iterdir(), key=lambda item: item.name.lower()):
        if path.suffix.lower() != ".json":
            continue
        count += 1
        if count > MAX_SEED_FILES:
            raise fail("too many identity seed files")
        if (
            SAFE_JSON_RE.fullmatch(path.name) is None
            or path.name.startswith(".")
            or ".." in path.name
        ):
            raise fail("unsafe identity seed filename", file=path.name)
        yield path


def load_identity_seed(root: Path, requested_alias: str) -> dict | None:
    if SLUG_RE.fullmatch(requested_alias) is None:
        raise fail("requested identity alias is invalid", key="identity_ref")
    selected: dict | None = None
    folded_aliases: set[str] = set()
    for path in seed_paths(root / "rigos" / "identities"):
        identity = read_seed_file(path)
        folded = identity["alias"].lower()
        if folded in folded_aliases:
            raise fail("duplicate identity seed alias", file=path.name, key="alias")
        folded_aliases.add(folded)
        if identity["alias"] == requested_alias:
            selected = identity
    return selected


def write_private_json(path: Path, value: dict) -> None:
    path.parent.mkdir(mode=0o755, parents=True, exist_ok=True)
    descriptor, name = tempfile.mkstemp(prefix=f".{path.name}-", dir=path.parent)
    temporary = Path(name)
    try:
        os.fchmod(descriptor, 0o600)
        with os.fdopen(descriptor, "w", encoding="utf-8", closefd=True) as stream:
            json.dump(value, stream, sort_keys=True)
            stream.write("\n")
            stream.flush()
            os.fsync(stream.fileno())
        os.replace(temporary, path)
        path.chmod(0o600)
        directory = os.open(path.parent, os.O_RDONLY | os.O_DIRECTORY)
        try:
            os.fsync(directory)
        finally:
            os.close(directory)
    finally:
        temporary.unlink(missing_ok=True)


def execute(alias: str, output: Path) -> dict:
    attestation = revalidate_attestation()
    with MountedPartition(attestation) as root:
        identity = load_identity_seed(root, alias)
    if identity is None:
        output.unlink(missing_ok=True)
        return {"outcome": "identity_seed_missing", "alias": alias}
    write_private_json(output, identity)
    return {
        "outcome": "identity_seed_ready",
        "alias": identity["alias"],
        "suffix": f"****{identity['value'][-4:]}",
    }


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--alias", required=True)
    parser.add_argument("--output", type=Path, required=True)
    args = parser.parse_args()
    try:
        result = execute(args.alias, args.output)
    except SeedError as error:
        args.output.unlink(missing_ok=True)
        print(json.dumps(error.diagnostic(), sort_keys=True), file=sys.stderr)
        return 2
    except Exception as error:
        args.output.unlink(missing_ok=True)
        diagnostic = fail(f"identity seed failed with {type(error).__name__}")
        print(json.dumps(diagnostic.diagnostic(), sort_keys=True), file=sys.stderr)
        return 2
    print(json.dumps(result, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
