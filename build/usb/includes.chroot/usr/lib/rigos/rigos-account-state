#!/usr/bin/python3
import json
import os
import stat
import sys
import tempfile
from pathlib import Path

RUNTIME_STATUS = Path("/run/rigos/state-status.json")
LIVE_SHADOW = Path("/etc/shadow")
STATE_DIR = Path("/var/lib/rigos/recovery")
STATE_SHADOW = STATE_DIR / "shadow"
MAX_SHADOW_BYTES = 1024 * 1024


class AccountStateError(Exception):
    pass


def state_ready() -> bool:
    try:
        return json.loads(RUNTIME_STATUS.read_text(encoding="utf-8")).get("outcome") == "ready"
    except (OSError, json.JSONDecodeError):
        return False


def validate_shadow(data: bytes) -> None:
    if not data or len(data) > MAX_SHADOW_BYTES or b"\x00" in data:
        raise AccountStateError("invalid shadow payload")
    try:
        lines = data.decode("ascii").splitlines()
    except UnicodeError as error:
        raise AccountStateError("invalid shadow encoding") from error
    matches = [line for line in lines if line.startswith("rigosadmin:")]
    if len(matches) != 1 or matches[0].count(":") < 7:
        raise AccountStateError("missing local administrator entry")


def ensure_state_dir() -> None:
    STATE_DIR.mkdir(mode=0o700, parents=True, exist_ok=True)
    metadata = STATE_DIR.lstat()
    if not stat.S_ISDIR(metadata.st_mode) or stat.S_ISLNK(metadata.st_mode):
        raise AccountStateError("unsafe account state directory")
    if metadata.st_uid != 0 or metadata.st_gid != 0:
        raise AccountStateError("invalid account state owner")
    if stat.S_IMODE(metadata.st_mode) != 0o700:
        STATE_DIR.chmod(0o700)


def atomic_write(path: Path, data: bytes, mode: int, uid: int, gid: int) -> None:
    with tempfile.NamedTemporaryFile(dir=path.parent, prefix=f".{path.name}-", delete=False) as stream:
        temporary = Path(stream.name)
        os.fchmod(stream.fileno(), mode)
        os.fchown(stream.fileno(), uid, gid)
        stream.write(data)
        stream.flush()
        os.fsync(stream.fileno())
    try:
        os.replace(temporary, path)
        directory = os.open(path.parent, os.O_RDONLY | os.O_DIRECTORY)
        try:
            os.fsync(directory)
        finally:
            os.close(directory)
    except OSError:
        temporary.unlink(missing_ok=True)
        raise


def snapshot() -> int:
    if not state_ready():
        return 0
    data = LIVE_SHADOW.read_bytes()
    validate_shadow(data)
    ensure_state_dir()
    atomic_write(STATE_SHADOW, data, 0o600, 0, 0)
    return 0


def restore() -> int:
    if not state_ready() or not STATE_SHADOW.exists():
        return 0
    metadata = STATE_SHADOW.lstat()
    if not stat.S_ISREG(metadata.st_mode) or stat.S_ISLNK(metadata.st_mode):
        raise AccountStateError("unsafe account state file")
    if metadata.st_uid != 0 or metadata.st_gid != 0 or stat.S_IMODE(metadata.st_mode) != 0o600:
        raise AccountStateError("invalid account state permissions")
    data = STATE_SHADOW.read_bytes()
    validate_shadow(data)
    live_metadata = LIVE_SHADOW.stat()
    atomic_write(
        LIVE_SHADOW,
        data,
        stat.S_IMODE(live_metadata.st_mode),
        live_metadata.st_uid,
        live_metadata.st_gid,
    )
    return 0


def main() -> int:
    if os.geteuid() != 0:
        print("rigos-account-state requires root", file=sys.stderr)
        return 1
    if len(sys.argv) != 2 or sys.argv[1] not in {"snapshot", "restore"}:
        print("usage: rigos-account-state <snapshot|restore>", file=sys.stderr)
        return 2
    try:
        return snapshot() if sys.argv[1] == "snapshot" else restore()
    except (AccountStateError, OSError):
        print("rigos-account-state failed", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
