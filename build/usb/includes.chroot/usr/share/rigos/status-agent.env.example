# This is a format example. Use rig-status-agent configure; do not copy it directly.
# Never place the ingest secret in this file.
RIGOS_STATUS_URL="http://STATUS-SERVER:8787"
RIGOS_STATUS_SECRET_FILE=/var/lib/rigos/status-agent/ingest.secret
RIGOS_STATUS_SOURCE_ID_FILE=/var/lib/rigos/status-agent/source-id
RIGOS_STATUS_STATUS_FILE=/var/lib/rigos/status-agent/last-send.json
RIGOS_STATUS_TIMEOUT=10
