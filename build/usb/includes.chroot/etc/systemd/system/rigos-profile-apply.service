[Unit]
Description=Apply RIGOS persistent machine profile
After=rigos-state-ready.service
Requires=rigos-state-ready.service
Before=rigos-firstboot.service rigos-hugepages.service rigos-miner.service

[Service]
Type=oneshot
ExecStart=/usr/lib/rigos/rigos-config timezone
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
